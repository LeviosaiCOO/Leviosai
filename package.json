{
  "name": "leviosai-crm",
  "version": "1.0.0",
  "description": "Leviosai AI-Powered Sales CRM",
  "type": "module",
  "scripts": {
    "dev": "tsx watch server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx scripts/seed.ts",
    "db:migrate": "drizzle-kit migrate",
    "client:dev": "cd client && npm run dev",
    "client:build": "cd client && npm run build",
    "client:install": "cd client && npm install"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@sendgrid/mail": "^8.1.0",
    "@sentry/node": "^10.47.0",
    "@vitejs/plugin-react": "^6.0.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.38.0",
    "drizzle-zod": "^0.8.3",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.2",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.13.0",
    "resend": "^6.10.0",
    "stripe": "^21.0.1",
    "twilio": "^5.4.0",
    "vite": "^8.0.3",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.11.0",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
